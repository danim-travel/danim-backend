# Django
SECRET_KEY=your-secret-key-here

# Database (docker-compose.yml 기본값 그대로 사용 가능)
DB_NAME=danim
DB_USER=danim
DB_PASSWORD=danim
DB_HOST=db
DB_PORT=5432

# Redis (docker-compose.yml 기본값 그대로 사용 가능)
REDIS_URL=redis://redis:6379/1
REDIS_AUTH_URL=redis://redis:6379/2

# Server (로컬에서는 아래 값 그대로 사용)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (로컬은 콘솔 출력으로 대체되므로 입력 불필요)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# AWS S3 (팀장에게 문의)
S3_REGION=ap-northeast-2
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_BUCKET_NAME=danim-media
S3_PREFIX=dev/
S3_PATH={action}/image/{category}/{suffix}

# Kakao OAuth
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=
FRONT_REDIRECT_URI=